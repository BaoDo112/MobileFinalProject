# Runtime
PORT=3100
JWT_SECRET="replace-with-a-long-random-secret"

# Neon Postgres
DATABASE_URL="postgresql://user:password@host.neon.tech:5432/arthera?sslmode=require"

# Optional override for local/debug use.
# Leave blank to auto-use Prisma when DATABASE_URL is present and NODE_ENV is not test.
ARTHERA_PERSISTENCE_DRIVER=""

# Optional local demo accounts used by the current Phase 1 auth bootstrap
ARTHERA_DEMO_VISITOR_PASSWORD=""
ARTHERA_DEMO_ORGANIZER_PASSWORD=""

# Prepare these now for the upcoming hosted API + OAuth phases
API_PUBLIC_URL="https://your-fly-app.fly.dev"
ALLOWED_ORIGINS="http://localhost:8081,http://127.0.0.1:8081,http://localhost:8082,http://127.0.0.1:8082,exp://127.0.0.1:8081,exp://127.0.0.1:8082"
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI="https://your-fly-app.fly.dev/api/auth/google/callback"

# Cloudflare R2 object storage used by /api/assets/*
# R2_PUBLIC_BASE_URL is optional when you later expose a public CDN or custom domain.
# The current runtime can proxy private R2 assets through the API, so a public bucket is not required.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_REGION="auto"
R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
R2_PUBLIC_BASE_URL="https://cdn.example.com"
