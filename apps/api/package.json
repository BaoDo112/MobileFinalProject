{
  "name": "@arthera/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "start": "nest start",
    "build": "nest build",
    "lint": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.spec.json",
    "test": "pnpm test:unit && pnpm test:integration && pnpm test:smoke",
    "test:unit": "jest --config ./jest.config.cjs --runInBand --testPathPattern=unit\\.spec\\.ts$",
    "test:integration": "jest --config ./jest.config.cjs --runInBand --testPathPattern=integration\\.spec\\.ts$",
    "test:smoke": "jest --config ./jest.config.cjs --runInBand --testPathPattern=v1_4_smoke\\.spec\\.ts$",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "prisma:seed": "prisma db seed",
    "prisma:bootstrap": "pnpm prisma:push && pnpm prisma:seed"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.916.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.1.3",
    "@prisma/client": "^6.5.0",
    "@sentry/node": "^10.54.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "29.5.14",
    "@types/node": "^22.13.9",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "6.0.3",
    "jest": "29.7.0",
    "prisma": "^6.5.0",
    "supertest": "7.1.0",
    "ts-jest": "29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
