generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  VISITOR
  ORGANIZER
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum ExhibitionStatus {
  DRAFT
  REVIEW
  PUBLISHED
  CLOSED
}

enum SessionStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
}

enum RegistrationStatus {
  PENDING
  CONFIRMED
  WAITLISTED
  REJECTED
  CHECKED_IN
  CANCELLED
}

enum ReviewStatus {
  PUBLISHED
  PENDING
  HIDDEN
  FLAGGED
}

enum StampSource {
  ATTENDANCE
  MILESTONE
}

enum StampVaultSection {
  CONFIRMED
  UPCOMING
  EXPIRED
}

enum FieldType {
  TEXT
  EMAIL
  PHONE
  TEXTAREA
  SELECT
}

model User {
  id                     String                  @id @default(cuid())
  email                  String                  @unique
  role                   UserRole
  preferredRole          UserRole?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  accounts               AuthAccount[]
  visitorProfile         VisitorProfile?
  organizerProfile       OrganizerProfile?
  registrations          Registration[]
  reviews                Review[]
  stamps                 Stamp[]
  exhibitions            Exhibition[]            @relation("OrganizerExhibitions")
  notificationPreference NotificationPreference?

  @@index([role])
}

model AuthAccount {
  id           String       @id @default(cuid())
  userId       String
  provider     AuthProvider
  providerId   String
  passwordHash String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@index([userId, provider])
}

model VisitorProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  name               String
  fullName           String?
  phoneNumber        String?
  tagline            String?
  city               String?
  membershipLabel    String?
  accessibilityNotes String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OrganizerProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  name             String
  organizationName String?
  phoneNumber      String?
  tagline          String?
  city             String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Venue {
  id                 String   @id @default(cuid())
  title              String
  district           String
  address            String
  city               String?
  mapUrl             String?
  latitude           Float?
  longitude          Float?
  accessibilityNotes String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  exhibitions Exhibition[]

  @@index([district, city])
}

model Exhibition {
  id             String           @id @default(cuid())
  organizerId    String
  venueId        String?
  title          String
  exhibitionType String
  bio            String           @db.Text
  curatorNote    String?          @db.Text
  policyText     String?          @db.Text
  mediaUrls      String[]         @default([])
  status         ExhibitionStatus @default(DRAFT)
  accent         String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organizer   User                @relation("OrganizerExhibitions", fields: [organizerId], references: [id])
  venue       Venue?              @relation(fields: [venueId], references: [id], onDelete: SetNull)
  sessions    ExhibitionSession[]
  formSchemas FormSchemaVersion[]
  reviews     Review[]
  stamps      Stamp[]

  @@index([status, venueId])
  @@index([organizerId, status])
  @@index([exhibitionType, status])
  @@index([createdAt])
}

model ExhibitionSession {
  id               String        @id @default(cuid())
  exhibitionId     String
  dateLabel        String
  timeLabel        String
  capacity         Int           @default(0)
  waitlistCapacity Int           @default(0)
  vibe             String?
  status           SessionStatus @default(SCHEDULED)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  exhibition    Exhibition     @relation(fields: [exhibitionId], references: [id], onDelete: Cascade)
  registrations Registration[]

  @@index([exhibitionId, status])
  @@index([dateLabel, timeLabel])
}

model FormSchemaVersion {
  id           String   @id @default(cuid())
  exhibitionId String
  version      Int
  isActive     Boolean  @default(false)
  consentTitle String?
  consentCopy  String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  exhibition    Exhibition     @relation(fields: [exhibitionId], references: [id], onDelete: Cascade)
  fields        FormField[]
  registrations Registration[]

  @@unique([exhibitionId, version])
  @@index([exhibitionId, isActive])
}

model FormField {
  id                  String    @id @default(cuid())
  formSchemaVersionId String
  type                FieldType
  label               String
  placeholder         String?
  isRequired          Boolean   @default(false)
  options             String[]  @default([])
  helpText            String?
  order               Int       @default(0)

  schemaVersion FormSchemaVersion   @relation(fields: [formSchemaVersionId], references: [id], onDelete: Cascade)
  answers       RegistrationAnswer[]

  @@unique([formSchemaVersionId, order])
}

model Registration {
  id                  String             @id @default(cuid())
  sessionId           String
  visitorId           String
  formSchemaVersionId String?
  status              RegistrationStatus @default(PENDING)
  note                String?            @db.Text
  decisionNote        String?            @db.Text
  submittedAt         DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  session       ExhibitionSession   @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  visitor       User                @relation(fields: [visitorId], references: [id])
  schemaVersion FormSchemaVersion?  @relation(fields: [formSchemaVersionId], references: [id])
  answers       RegistrationAnswer[]
  attendanceLog AttendanceLog?
  stamps        Stamp[]

  @@unique([sessionId, visitorId])
  @@index([sessionId, status])
  @@index([visitorId, status])
  @@index([submittedAt])
}

model RegistrationAnswer {
  id             String @id @default(cuid())
  registrationId String
  formFieldId    String
  value          String @db.Text

  registration Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  field        FormField    @relation(fields: [formFieldId], references: [id])

  @@unique([registrationId, formFieldId])
}

model Review {
  id           String       @id @default(cuid())
  exhibitionId String
  visitorId    String
  rating       Int
  content      String       @db.Text
  status       ReviewStatus @default(PUBLISHED)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  exhibition Exhibition @relation(fields: [exhibitionId], references: [id], onDelete: Cascade)
  visitor    User       @relation(fields: [visitorId], references: [id])

  @@unique([exhibitionId, visitorId])
  @@index([exhibitionId, status])
  @@index([visitorId, status])
}

model AttendanceLog {
  id             String   @id @default(cuid())
  registrationId String   @unique
  note           String?  @db.Text
  checkedInAt    DateTime @default(now())

  registration Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([checkedInAt])
}

model Stamp {
  id             String      @id @default(cuid())
  visitorId      String
  exhibitionId   String
  registrationId String?
  source         StampSource
  vaultSection   StampVaultSection @default(CONFIRMED)
  title          String
  milestone      String?
  note           String?
  accent         String?
  unlockedAt     DateTime    @default(now())

  owner        User          @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  exhibition   Exhibition    @relation(fields: [exhibitionId], references: [id], onDelete: Cascade)
  registration Registration? @relation(fields: [registrationId], references: [id], onDelete: SetNull)

  @@index([visitorId, unlockedAt])
  @@index([exhibitionId, source])
}

model NotificationPreference {
  id             String   @id @default(cuid())
  userId         String   @unique
  emailAlerts    Boolean  @default(true)
  pushAlerts     Boolean  @default(false)
  reminderAlerts Boolean  @default(true)
  queueAlerts    Boolean  @default(true)
  marketingOptIn Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
