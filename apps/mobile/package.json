{
  "name": "@arthera/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "expo start --port 8082",
    "dev:go": "expo start --tunnel --clear --port 8082",
    "lint": "tsc --noEmit",
    "test": "pnpm test:unit && pnpm test:integration && pnpm test:smoke",
    "test:unit": "jest --config ./jest.config.cjs --runInBand --testPathPattern=unit\\.test\\.tsx?$",
    "test:integration": "jest --config ./jest.config.cjs --runInBand --testPathPattern=integration\\.test\\.tsx?$",
    "test:smoke": "jest --config ./jest.config.cjs --runInBand --runTestsByPath ./src/test/v1_4_screen_contract.spec.tsx",
    "build": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.1.1",
    "@hookform/resolvers": "^5.2.2",
    "@react-navigation/bottom-tabs": "^7.1.0",
    "@react-navigation/native": "^7.0.10",
    "@react-navigation/native-stack": "^7.0.10",
    "@tanstack/react-query": "^5.100.10",
    "date-fns": "^4.1.0",
    "expo": "~54.0.34",
    "expo-auth-session": "~7.0.11",
    "expo-blur": "~15.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.11",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.75.0",
    "react-native": "0.81.5",
    "react-native-maps": "^1.20.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.2",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@testing-library/jest-native": "5.4.3",
    "@testing-library/react-native": "13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.1.17",
    "jest": "29.7.0",
    "jest-expo": "~54.0.17",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.3"
  }
}
