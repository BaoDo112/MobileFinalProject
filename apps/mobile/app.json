{
  "expo": {
    "name": "Arthera",
    "slug": "arthera",
    "version": "0.1.0",
    "scheme": "arthera",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#fffdf0"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.arthera.mobile",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#fffdf0"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.arthera.mobile",
      "versionCode": 1
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-web-browser"
    ],
    "extra": {
      "apiUrl": "http://192.168.1.98:3100",
      "eas": {
        "projectId": "af9250c9-47cd-4ee9-a561-ce6680a47f3e"
      }
    }
  }
}
